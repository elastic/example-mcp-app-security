{
  "name": "elastic-security",
  "version": "0.1.0",
  "description": "Interactive blue-team security operations for Elastic Security — alert triage, attack discovery, case management, detection rules, threat hunting, and sample data generation",
  "author": {
    "name": "Elastic"
  },
  "homepage": "https://github.com/elastic/example-mcp-app-security",
  "repository": "https://github.com/elastic/example-mcp-app-security",
  "license": "Apache-2.0",
  "keywords": [
    "security",
    "elastic",
    "siem",
    "soc",
    "alerts",
    "detection",
    "threat-hunting"
  ],

  "skills": "./skills/",
  "agents": ["./agents/security-analyst.md"],

  "userConfig": {
    "elasticsearch_url": {
      "title": "Elasticsearch URL",
      "description": "Elasticsearch URL (e.g. https://your-cluster.es.cloud.example.com)",
      "type": "string",
      "sensitive": false
    },
    "elasticsearch_api_key": {
      "title": "Elasticsearch API Key",
      "description": "API key for Elasticsearch authentication",
      "type": "string",
      "sensitive": true
    },
    "kibana_url": {
      "title": "Kibana URL",
      "description": "Kibana URL (e.g. https://your-cluster.kb.cloud.example.com)",
      "type": "string",
      "sensitive": false
    },
    "kibana_api_key": {
      "title": "Kibana API Key",
      "description": "API key for Kibana authentication",
      "type": "string",
      "sensitive": true
    }
  },

  "mcpServers": {
    "elastic-security": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/elastic-security-mcp",
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules"
      }
    }
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/package.json\" \"${CLAUDE_PLUGIN_DATA}/package.json\" >/dev/null 2>&1 || (cd \"${CLAUDE_PLUGIN_DATA}\" && cp \"${CLAUDE_PLUGIN_ROOT}/package.json\" . && npm install --omit=dev) || rm -f \"${CLAUDE_PLUGIN_DATA}/package.json\""
          }
        ]
      }
    ]
  }
}
